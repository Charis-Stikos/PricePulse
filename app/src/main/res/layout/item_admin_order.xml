<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/orderCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/orderCardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/adminOrderId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="#ORD-1024"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/skroutz_text_primary"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/adminOrderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Today, 14:30"
                    android:textSize="12sp"
                    android:textColor="@color/skroutz_text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/adminOrderStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/pending_label"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/skroutz_orange"
                android:background="@drawable/bg_status_pending" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_rounded_gray"
            android:padding="12dp">

            <TextView
                android:id="@+id/adminOrderUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer: User 001"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_primary" />

            <TextView
                android:id="@+id/adminOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="3 items"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/order_total_label"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_secondary" />

            <TextView
                android:id="@+id/adminOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€245.90"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/skroutz_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/orderActionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminOrderViewBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="@string/view_order"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/skroutz_orange"
                app:strokeColor="@color/skroutz_orange"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminOrderUpdateBtn"
                style="@style/Widget.App.OrangeButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/update_status"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminOrderDetailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_rounded_gray"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/order_items"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/skroutz_text_primary" />

            <TextView
                android:id="@+id/adminOrderDetailsItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_secondary" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
