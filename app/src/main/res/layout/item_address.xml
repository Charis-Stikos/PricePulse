<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:id="@+id/addressCardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_orange_soft">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_location"
                    app:tint="@color/skroutz_orange"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/addressLabelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/skroutz_text_primary"/>

                <TextView
                    android:id="@+id/defaultBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/bg_default_badge"
                    android:text="@string/address_default_badge"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/skroutz_orange"
                    android:visibility="gone"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/addressEditButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/address_edit"
                app:tint="@color/skroutz_text_secondary"/>

            <ImageButton
                android:id="@+id/addressDeleteButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_delete_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/address_delete"
                app:tint="@color/error_red"/>
        </LinearLayout>

        <TextView
            android:id="@+id/addressFullNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/skroutz_text_primary"/>

        <TextView
            android:id="@+id/addressLineText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@color/skroutz_text_secondary"/>

        <TextView
            android:id="@+id/addressPhoneText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@color/skroutz_text_secondary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addressSetDefaultButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="0dp"
            android:minHeight="32dp"
            android:text="@string/address_set_as_default"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/skroutz_blue"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
