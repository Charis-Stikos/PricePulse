<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/skroutz_gray">

    <!-- LIST VIEW -->
    <LinearLayout
        android:id="@+id/shopsListContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addShopButton"
            style="@style/Widget.App.OrangeButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/add_shop"
            app:icon="@drawable/ic_add"
            app:iconTint="@color/white"
            app:iconGravity="textStart"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"
            android:text="@string/admin_shops_list_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/skroutz_text_secondary"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/shopsRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"/>

            <TextView
                android:id="@+id/shopsEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/no_shops_yet"
                android:textColor="@color/skroutz_text_secondary"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

    <!-- EDITOR VIEW (overlaps list, shown when adding/editing) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/shopEditorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:background="@color/skroutz_gray"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/shopEditorTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_shop"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/skroutz_text_primary"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/shop_name_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editorShopNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/shop_description_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editorShopDescriptionInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="2"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/shop_category_hint">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/editorShopCategoryInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/shop_email_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editorShopEmailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/shop_phone_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editorShopPhoneInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/shop_address_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editorShopAddressInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress|textCapSentences"
                            android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/editorShopActiveSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/shop_active_label"
                        android:textColor="@color/skroutz_text_primary"
                        android:textSize="15sp"
                        android:checked="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/cancelShopEditorButton"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="@android:string/cancel"
                            android:textAllCaps="false"
                            android:textColor="@color/skroutz_text_primary"
                            app:strokeColor="@color/skroutz_border"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/saveShopButton"
                                style="@style/Widget.App.OrangeButton"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/save_shop_details"/>

                            <ProgressBar
                                android:id="@+id/saveShopProgress"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:indeterminateTint="@color/white"
                                android:visibility="gone"/>
                        </FrameLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
