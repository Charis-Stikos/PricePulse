<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/picker_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/skroutz_text_primary"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pickerRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:nestedScrollingEnabled="true"/>

    <TextView
        android:id="@+id/pickerEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/picker_no_saved_addresses"
        android:textSize="14sp"
        android:textColor="@color/skroutz_text_secondary"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>
