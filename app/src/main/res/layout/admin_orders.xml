<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/skroutz_gray"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/orderSummaryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/ordersOverviewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_overview"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/skroutz_text_primary" />

            <TextView
                android:id="@+id/ordersOverviewSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/orders_overview_subtitle"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/totalOrdersCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/skroutz_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_orders_label"
                        android:textSize="12sp"
                        android:textColor="@color/skroutz_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/pendingOrdersCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/skroutz_orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pending_label"
                        android:textSize="12sp"
                        android:textColor="@color/skroutz_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/completedOrdersCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/success_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/completed_label"
                        android:textSize="12sp"
                        android:textColor="@color/skroutz_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/orderFilterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/filter_all"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_chip_selected" />

            <TextView
                android:id="@+id/filterPending"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/pending_label"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_primary"
                android:background="@drawable/bg_chip_unselected" />

            <TextView
                android:id="@+id/filterCompleted"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/completed_label"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/skroutz_text_primary"
                android:background="@drawable/bg_chip_unselected" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/recent_orders"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/skroutz_text_secondary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/adminOrdersRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_admin_order" />

        <ProgressBar
            android:id="@+id/adminOrdersProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/skroutz_orange"
            android:visibility="gone" />

        <TextView
            android:id="@+id/adminOrdersEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/empty_admin_orders"
            android:textColor="@color/skroutz_text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
