<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/skroutz_gray">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="96dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/shopHeaderCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_circle_orange">

                        <TextView
                            android:id="@+id/shopInitialPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="S"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/shopPreviewName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sample_shop_name"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/skroutz_text_primary" />

                        <TextView
                            android:id="@+id/shopPreviewSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/shop_details_subtitle"
                            android:textSize="13sp"
                            android:textColor="@color/skroutz_text_secondary" />

                        <TextView
                            android:id="@+id/shopPreviewStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/shop_status_active"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_green" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/basic_information"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/skroutz_text_secondary" />

            <androidx.cardview.widget.CardView
                android:id="@+id/basicShopInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopNameInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/shop_name_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/shopNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:maxLines="1"
                            android:text="@string/sample_shop_name" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopDescriptionInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/shop_description_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/shopDescriptionInput"
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences"
                            android:maxLines="5"
                            android:text="@string/sample_shop_description" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopCategoryInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout.ExposedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/shop_category_hint">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/shopCategoryDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="@string/category_electronics" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/contact_information"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/skroutz_text_secondary" />

            <androidx.cardview.widget.CardView
                android:id="@+id/contactShopInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopEmailInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/shop_email_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/shopEmailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:text="@string/sample_shop_email" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopPhoneInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/shop_phone_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/shopPhoneInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:maxLines="1"
                            android:text="@string/sample_shop_phone" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/shopAddressInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/shop_address_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/shopAddressInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress|textCapSentences"
                            android:maxLines="2"
                            android:text="@string/sample_shop_address" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/business_information"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/skroutz_text_secondary" />

            <androidx.cardview.widget.CardView
                android:id="@+id/businessShopInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/openingHoursInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/opening_hours_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/openingHoursInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences"
                            android:maxLines="1"
                            android:text="@string/sample_opening_hours" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/deliveryOptionsInputLayout"
                        style="@style/Widget.App.RoundedTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/delivery_options_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/deliveryOptionsInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences"
                            android:maxLines="2"
                            android:text="@string/sample_delivery_options" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/editShopBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="16dp"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveShopDetailsButton"
            style="@style/Widget.App.OrangeButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/save_shop_details"
            android:textSize="17sp" />
    </LinearLayout>
</LinearLayout>
